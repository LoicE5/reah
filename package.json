{
  "name": "reah-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db": "podman compose -f docker/docker-compose.yml --env-file .env up",
    "db:generate": "bunx drizzle-kit generate",
