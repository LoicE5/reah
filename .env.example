# Database (Docker Compose)
DB_HOST=localhost
DB_PORT=3306
DB_USER=reah_user
DB_PASSWORD=reah_password
DB_NAME=reah_db
DB_ROOT_PASSWORD=root_password_change_me

# Session — must be at least 32 random characters
SESSION_SECRET=change_me_to_a_random_32_char_string_here_please

# Vimeo API — get from https://developer.vimeo.com/apps
VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=
VIMEO_ACCESS_TOKEN=

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="REAH <noreply@reah.fr>"

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
